{
  "name": "southstar-eds-site",
  "version": "1.0.0",
  "description": "AEM Edge Delivery Services site with React blocks",
  "type": "module",
  "scripts": {
    "dev": "aem up",
    "build": "vite build",
    "build:models": "node scripts/build-models.js",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "preview": "node scripts/preview-server/index.js",
    "lint": "eslint blocks scripts && stylelint styles blocks/**/*.css",
    "lint:fix": "eslint --fix blocks scripts",
    "format": "prettier --write . --ignore-unknown",
    "format:check": "prettier --check . --ignore-unknown",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@storybook/addon-docs": "10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "chokidar": "^3.6.0",
    "eslint": "^8.57.0",
    "eslint-plugin-storybook": "10.4.1",
    "express": "^4.19.0",
    "glob": "^11.0.0",
    "husky": "^9.1.7",
    "jsdom": "^24.0.0",
    "prettier": "^3.8.3",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "storybook": "^10.4.1",
    "stylelint": "^16.0.0",
    "stylelint-config-standard": "^36.0.0",
    "vite": "^5.0.0",
    "vitest": "^1.6.0"
  }
}
